# Order Status MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ERP SYSTEM CONFIGURATION
# =============================================================================
# Supported types: d365 (Dynamics 365 SCM), sap (SAP S/4HANA), generic
ERP_TYPE=generic
ERP_BASE_URL=https://your-erp-instance.com

# For API key authentication (generic ERP)
ERP_API_KEY=your-erp-api-key

# For OAuth authentication (D365, SAP)
ERP_CLIENT_ID=your-client-id
ERP_CLIENT_SECRET=your-client-secret
ERP_TENANT_ID=your-azure-tenant-id

# For Basic authentication (some SAP configurations)
ERP_USERNAME=your-username
ERP_PASSWORD=your-password

# =============================================================================
# SHIPPING CARRIER CONFIGURATION
# =============================================================================
# Supported carriers: shipstation, fedex, ups, generic
SHIPPING_CARRIER=shipstation
SHIPPING_BASE_URL=https://ssapi.shipstation.com

# ShipStation credentials
SHIPPING_API_KEY=your-shipstation-api-key
SHIPPING_API_SECRET=your-shipstation-api-secret

# FedEx credentials (if using FedEx directly)
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret

# UPS credentials (if using UPS directly)
UPS_CLIENT_ID=your-ups-client-id
UPS_CLIENT_SECRET=your-ups-client-secret
UPS_ACCOUNT_NUMBER=your-ups-account-number

# =============================================================================
# INVENTORY SYSTEM CONFIGURATION
# =============================================================================
# Supported types: erp (uses ERP connection), wms, generic
INVENTORY_SYSTEM_TYPE=erp

# If using a separate inventory/WMS system
INVENTORY_BASE_URL=https://your-wms-instance.com
INVENTORY_API_KEY=your-inventory-api-key

# For OAuth authentication (if different from ERP)
INVENTORY_CLIENT_ID=your-inventory-client-id
INVENTORY_CLIENT_SECRET=your-inventory-client-secret
INVENTORY_TENANT_ID=your-inventory-tenant-id

# Default warehouse for queries (optional)
DEFAULT_WAREHOUSE_ID=MAIN

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8000

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# --- Microsoft Dynamics 365 Supply Chain Management ---
# ERP_TYPE=d365
# ERP_BASE_URL=https://your-org.operations.dynamics.com
# ERP_CLIENT_ID=your-azure-app-client-id
# ERP_CLIENT_SECRET=your-azure-app-client-secret
# ERP_TENANT_ID=your-azure-tenant-id
# INVENTORY_SYSTEM_TYPE=erp

