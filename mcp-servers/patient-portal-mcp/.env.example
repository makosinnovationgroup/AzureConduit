# Patient Portal MCP Server Configuration
#
# HIPAA SECURITY WARNING:
# - Never commit actual credentials to version control
# - Use secure secret management (Azure Key Vault, AWS Secrets Manager, etc.)
# - Rotate credentials regularly
# - Restrict access to this file in production

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# EHR System Configuration
# =============================================================================
# Supported systems: epic, cerner, generic_fhir
EHR_SYSTEM=generic_fhir

# FHIR Base URL (your EHR's FHIR R4 endpoint)
EHR_BASE_URL=https://fhir.example.com/r4

# OAuth 2.0 / SMART on FHIR Credentials
# SECURITY: Store these in a secrets manager, not in environment files
EHR_CLIENT_ID=your_client_id
EHR_CLIENT_SECRET=your_client_secret

# OAuth endpoints (if different from base URL defaults)
EHR_TOKEN_ENDPOINT=https://auth.example.com/oauth2/token
EHR_AUTHORIZE_ENDPOINT=https://auth.example.com/oauth2/authorize

# Request timeout in milliseconds
EHR_TIMEOUT=30000

# =============================================================================
# Epic-specific Configuration (if using Epic)
# =============================================================================
# EPIC_CLIENT_ID=your_epic_client_id
# EPIC_PRIVATE_KEY_PATH=/path/to/private_key.pem

# =============================================================================
# Cerner-specific Configuration (if using Cerner)
# =============================================================================
# CERNER_SYSTEM_ACCOUNT=your_system_account

# =============================================================================
# Scheduling Configuration
# =============================================================================
# Use EHR's native scheduling module or external system
USE_EHR_SCHEDULING=true

# External scheduling API (if not using EHR)
# SCHEDULING_API_URL=https://scheduling.example.com/api
# SCHEDULING_API_KEY=your_api_key

# Default appointment duration in minutes
DEFAULT_APPOINTMENT_DURATION=30

# Maximum days in advance for booking
MAX_ADVANCE_BOOKING_DAYS=90

# Minimum hours notice for cancellation
MIN_CANCELLATION_NOTICE_HOURS=24

# =============================================================================
# Billing Configuration
# =============================================================================
# Use EHR's billing module or external system
USE_EHR_BILLING=true

# External billing system (if not using EHR)
# BILLING_SYSTEM_URL=https://billing.example.com/api
# BILLING_API_KEY=your_api_key

# Currency for billing amounts
BILLING_CURRENCY=USD

# =============================================================================
# HIPAA Audit Configuration
# =============================================================================
# Audit log destination (console, file, or external service)
AUDIT_LOG_DESTINATION=console

# External audit service (if using SIEM or audit platform)
# AUDIT_SERVICE_URL=https://audit.example.com/api
# AUDIT_SERVICE_API_KEY=your_api_key

# Audit log file path (if using file destination)
# AUDIT_LOG_PATH=/var/log/hipaa-audit/audit.log

# =============================================================================
# Security Configuration
# =============================================================================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Enable rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# CORS configuration (comma-separated allowed origins)
# CORS_ALLOWED_ORIGINS=https://portal.example.com,https://admin.example.com
