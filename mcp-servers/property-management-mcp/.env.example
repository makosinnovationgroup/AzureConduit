# Property Management System Configuration
# Supported providers: appfolio, buildium, generic
PROPERTY_MANAGEMENT_PROVIDER=generic

# AppFolio Configuration (if using AppFolio)
# API documentation: https://help.appfolio.com/s/article/AppFolio-API-Documentation
APPFOLIO_CLIENT_ID=your_client_id
APPFOLIO_CLIENT_SECRET=your_client_secret
APPFOLIO_DATABASE_NAME=your_database_name

# Buildium Configuration (if using Buildium)
# API documentation: https://developer.buildium.com/
BUILDIUM_CLIENT_ID=your_client_id
BUILDIUM_CLIENT_SECRET=your_client_secret

# Generic API Configuration (for custom property management systems)
# Use this for custom integrations or self-hosted systems
PROPERTY_API_BASE_URL=https://api.your-property-system.com
PROPERTY_API_KEY=your_api_key
PROPERTY_API_SECRET=your_api_secret

# Server Configuration
PORT=8000
LOG_LEVEL=info

# Optional: Demo mode (uses mock data for testing)
DEMO_MODE=true
