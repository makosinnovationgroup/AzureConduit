# Zendesk Configuration
# Your Zendesk subdomain (e.g., if your URL is https://mycompany.zendesk.com, use 'mycompany')
ZENDESK_SUBDOMAIN=your_subdomain

# The email address of the Zendesk user (must have API access)
ZENDESK_EMAIL=your_email@company.com

# API Token generated from Zendesk Admin > Apps and integrations > APIs > Zendesk API
ZENDESK_API_TOKEN=your_api_token

# Server Configuration
PORT=8000
LOG_LEVEL=info
