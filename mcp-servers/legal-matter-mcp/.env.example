# Legal Matter MCP Server Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8000
DEBUG=false

# =============================================================================
# Matter Management Platform Configuration
# =============================================================================
# Supported platforms: clio, practicepanther, custom
MATTER_PLATFORM=clio

# Base URL for your matter management system API
# Clio: https://app.clio.com
# PracticePanther: https://app.practicepanther.com
# Custom: Your own API endpoint
MATTER_BASE_URL=https://app.clio.com

# =============================================================================
# Authentication
# =============================================================================
# Option 1: OAuth2 Access Token (recommended for Clio, PracticePanther)
# Obtain via OAuth2 flow - see README for setup instructions
MATTER_ACCESS_TOKEN=your_oauth_access_token

# OAuth2 Refresh Token (for automatic token refresh)
MATTER_REFRESH_TOKEN=your_oauth_refresh_token

# OAuth2 Client Credentials (for token refresh)
MATTER_CLIENT_ID=your_client_id
MATTER_CLIENT_SECRET=your_client_secret

# Option 2: API Key (for systems that support it)
# MATTER_API_KEY=your_api_key

# =============================================================================
# Clio-Specific Configuration (if using Clio)
# =============================================================================
# Clio API Region (us, eu, ca, au)
# CLIO_REGION=us

# =============================================================================
# PracticePanther-Specific Configuration (if using PracticePanther)
# =============================================================================
# PracticePanther API Version
# PP_API_VERSION=v2

# =============================================================================
# Security & Compliance (IMPORTANT FOR LEGAL DATA)
# =============================================================================
# Enable audit logging for all data access (recommended)
AUDIT_LOGGING_ENABLED=true

# Restrict access to certain practice areas (comma-separated)
# ALLOWED_PRACTICE_AREAS=Litigation,Corporate,Real Estate

# Mask sensitive fields in responses (client SSN, financial info)
MASK_SENSITIVE_DATA=true

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# =============================================================================
# Rate Limiting
# =============================================================================
# Maximum requests per minute to the matter management API
API_RATE_LIMIT=100
