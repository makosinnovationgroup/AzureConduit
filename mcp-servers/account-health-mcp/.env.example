# =============================================================================
# Account Health MCP Server - Environment Configuration
# =============================================================================
# This server aggregates data from multiple systems to provide account health
# insights. Configure the systems you want to use below.
# =============================================================================

# Server Configuration
PORT=8000
LOG_LEVEL=info

# =============================================================================
# CRM CONNECTOR CONFIGURATION
# =============================================================================
# Choose one: salesforce or dynamics365
CRM_PROVIDER=salesforce

# Salesforce Configuration
# Obtain from Salesforce Setup > Apps > App Manager
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your_salesforce_client_id
SF_CLIENT_SECRET=your_salesforce_client_secret
SF_USERNAME=your_salesforce_username
SF_PASSWORD=your_salesforce_password_with_security_token

# Dynamics 365 Configuration (alternative to Salesforce)
# Obtain from Azure Portal > App Registrations
D365_TENANT_ID=your_azure_tenant_id
D365_CLIENT_ID=your_d365_client_id
D365_CLIENT_SECRET=your_d365_client_secret
D365_RESOURCE_URL=https://your-org.crm.dynamics.com

# =============================================================================
# FINANCE CONNECTOR CONFIGURATION
# =============================================================================
# Choose one: quickbooks or dynamics365_finance
FINANCE_PROVIDER=quickbooks

# QuickBooks Online Configuration
# Obtain from Intuit Developer Portal: https://developer.intuit.com
QB_CLIENT_ID=your_quickbooks_client_id
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REALM_ID=your_company_realm_id
QB_REFRESH_TOKEN=your_oauth_refresh_token
QB_ENVIRONMENT=sandbox

# Dynamics 365 Finance Configuration (alternative to QuickBooks)
# Uses same Azure AD app as CRM if configured
D365_FINANCE_RESOURCE_URL=https://your-org.operations.dynamics.com

# =============================================================================
# SUPPORT CONNECTOR CONFIGURATION
# =============================================================================
# Choose one: zendesk or servicenow
SUPPORT_PROVIDER=zendesk

# Zendesk Configuration
# Obtain from Zendesk Admin > Apps and Integrations > APIs
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your_admin_email@company.com
ZENDESK_API_TOKEN=your_zendesk_api_token

# ServiceNow Configuration (alternative to Zendesk)
# Obtain from ServiceNow instance admin
SERVICENOW_INSTANCE=your-instance
SERVICENOW_USERNAME=your_servicenow_username
SERVICENOW_PASSWORD=your_servicenow_password
SERVICENOW_CLIENT_ID=your_servicenow_client_id
SERVICENOW_CLIENT_SECRET=your_servicenow_client_secret

# =============================================================================
# HEALTH SCORE CONFIGURATION
# =============================================================================
# Weights for health score calculation (must sum to 1.0)
HEALTH_WEIGHT_REVENUE=0.30
HEALTH_WEIGHT_PAYMENT=0.25
HEALTH_WEIGHT_SUPPORT=0.25
HEALTH_WEIGHT_ENGAGEMENT=0.20

# Thresholds for "at risk" classification
AT_RISK_HEALTH_THRESHOLD=60
REVENUE_DECLINE_THRESHOLD=0.15
SUPPORT_TICKETS_WARNING=5
PAYMENT_DAYS_OVERDUE_WARNING=30
