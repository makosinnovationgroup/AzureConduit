# CRM Provider Configuration
# Supported providers: salesforce, d365, generic
CRM_PROVIDER=salesforce

# ============================================
# Salesforce Configuration (if CRM_PROVIDER=salesforce)
# ============================================
# Login URL (use https://login.salesforce.com for production, https://test.salesforce.com for sandbox)
SF_LOGIN_URL=https://login.salesforce.com

# Connected App OAuth2 Credentials
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Salesforce User Credentials (for password OAuth flow)
SF_USERNAME=your_salesforce_username
SF_PASSWORD=your_salesforce_password_with_security_token

# ============================================
# Dynamics 365 Sales Configuration (if CRM_PROVIDER=d365)
# ============================================
D365_TENANT_ID=your_azure_ad_tenant_id
D365_CLIENT_ID=your_azure_ad_app_client_id
D365_CLIENT_SECRET=your_azure_ad_app_client_secret
D365_RESOURCE_URL=https://your-org.crm.dynamics.com

# ============================================
# Generic CRM Configuration (if CRM_PROVIDER=generic)
# ============================================
GENERIC_API_BASE_URL=https://your-crm-api.example.com
GENERIC_API_KEY=your_api_key
GENERIC_API_SECRET=your_api_secret

# ============================================
# Server Configuration
# ============================================
PORT=8000
LOG_LEVEL=info

# ============================================
# Sales Configuration
# ============================================
# Default number of days to consider a deal "stalled" with no activity
STALLED_DAYS_THRESHOLD=14

# Fiscal year start month (1-12, where 1 = January)
FISCAL_YEAR_START_MONTH=1

# Currency symbol for display
CURRENCY_SYMBOL=$

# Default pipeline stages (comma-separated)
PIPELINE_STAGES=Prospecting,Qualification,Proposal,Negotiation,Closed Won,Closed Lost
