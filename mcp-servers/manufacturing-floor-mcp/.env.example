# Manufacturing Floor MCP Server Configuration

# Server Configuration
PORT=8000
LOG_LEVEL=info

# MES (Manufacturing Execution System) Configuration
MES_BASE_URL=http://localhost:8080
MES_API_KEY=your-mes-api-key
MES_PLANT_ID=PLANT-001

# ERP System Configuration
ERP_BASE_URL=http://localhost:8081
ERP_API_KEY=your-erp-api-key
ERP_COMPANY_ID=COMPANY-001

# Quality Management System Configuration
QUALITY_BASE_URL=http://localhost:8082
QUALITY_API_KEY=your-quality-api-key
QUALITY_SITE_ID=SITE-001

# Optional: Connection Timeouts (milliseconds)
# MES_TIMEOUT=30000
# ERP_TIMEOUT=30000
# QUALITY_TIMEOUT=30000

# Optional: Retry Configuration
# API_RETRY_COUNT=3
# API_RETRY_DELAY=1000
