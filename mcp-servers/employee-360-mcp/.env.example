# Employee 360 MCP Server Configuration
# This server aggregates data from multiple enterprise systems

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8000

# =============================================================================
# AZURE AD / ENTRA ID CONFIGURATION
# Used for: Directory connector, Intune connector, Activity logs
# Required permissions:
#   - User.Read.All (read user profiles)
#   - Directory.Read.All (read org structure)
#   - DeviceManagementManagedDevices.Read.All (read Intune devices)
#   - AuditLog.Read.All (read sign-in and audit logs)
#   - IdentityRiskEvent.Read.All (read security alerts - requires Azure AD P2)
# =============================================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# =============================================================================
# HR SYSTEM CONFIGURATION
# Supported types: bamboohr, workday, generic
# =============================================================================
HR_SYSTEM_TYPE=bamboohr

# BambooHR Configuration
# Get API key from: BambooHR > Settings > API Keys
HR_API_URL=https://api.bamboohr.com/api/gateway.php/YOUR_COMPANY
HR_API_KEY=your-bamboohr-api-key
HR_COMPANY_DOMAIN=your-company

# Workday Configuration (alternative to BambooHR)
# HR_SYSTEM_TYPE=workday
# HR_API_URL=https://wd5-services1.myworkday.com/ccx/api/v1/YOUR_TENANT
# HR_CLIENT_ID=your-workday-client-id
# HR_CLIENT_SECRET=your-workday-client-secret
# HR_TENANT_ID=your-workday-tenant

# Generic HR API Configuration (for custom HR systems)
# HR_SYSTEM_TYPE=generic
# HR_API_URL=https://your-hr-system.example.com/api
# HR_API_KEY=your-api-key
# HR_CLIENT_ID=your-client-id
# HR_CLIENT_SECRET=your-client-secret

# =============================================================================
# IT ASSET SYSTEM CONFIGURATION
# Supported types: intune, servicenow, generic
# =============================================================================
IT_ASSET_SYSTEM_TYPE=intune

# Intune uses the same Azure AD credentials above

# ServiceNow Configuration (alternative to Intune)
# IT_ASSET_SYSTEM_TYPE=servicenow
# SERVICENOW_URL=https://your-instance.service-now.com
# SERVICENOW_USERNAME=your-username
# SERVICENOW_PASSWORD=your-password

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# NOTES ON SETTING UP AZURE AD APP REGISTRATION
# =============================================================================
# 1. Go to Azure Portal > Azure Active Directory > App registrations
# 2. Create a new registration with a descriptive name
# 3. Note the Application (client) ID and Directory (tenant) ID
# 4. Create a client secret under Certificates & secrets
# 5. Add API permissions:
#    - Microsoft Graph > Application permissions:
#      - User.Read.All
#      - Directory.Read.All
#      - DeviceManagementManagedDevices.Read.All
#      - AuditLog.Read.All
#      - IdentityRiskEvent.Read.All (optional, requires P2)
# 6. Grant admin consent for the permissions
#
# For BambooHR:
# 1. Log into BambooHR as an admin
# 2. Go to Settings > Access > API Keys
# 3. Create a new API key with appropriate permissions
#
# For ServiceNow:
# 1. Create a service account with CMDB read access
# 2. Ensure the account can query cmdb_ci_computer table
# 3. For software inventory, grant access to cmdb_sam_sw_install table
