# QuickBooks Online API Credentials
# Obtain these from the Intuit Developer Portal: https://developer.intuit.com

# OAuth2 Client ID from your QuickBooks app
QB_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret from your QuickBooks app
QB_CLIENT_SECRET=your_client_secret_here

# Company/Realm ID - found in the URL when logged into QuickBooks Online
# Example: https://app.qbo.intuit.com/app/homepage?realmId=123456789012345
QB_REALM_ID=your_realm_id_here

# OAuth2 Refresh Token - obtained through the OAuth flow
# This token is used to obtain new access tokens
QB_REFRESH_TOKEN=your_refresh_token_here

# Environment: sandbox or production
QB_ENVIRONMENT=sandbox

# Server Configuration
PORT=8000
LOG_LEVEL=info
