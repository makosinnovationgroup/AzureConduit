# REST API MCP Server Configuration

# Base URL for the REST API (required)
API_BASE_URL=https://api.example.com

# Authentication type: none, api-key, bearer, basic, oauth2
API_AUTH_TYPE=none

# API Key authentication (when API_AUTH_TYPE=api-key)
API_KEY=your-api-key-here
API_KEY_HEADER=X-API-Key

# Bearer token authentication (when API_AUTH_TYPE=bearer)
API_TOKEN=your-bearer-token-here

# Basic authentication (when API_AUTH_TYPE=basic)
API_BASIC_USERNAME=your-username
API_BASIC_PASSWORD=your-password

# OAuth2 authentication (when API_AUTH_TYPE=oauth2)
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_TOKEN_URL=https://auth.example.com/oauth/token
OAUTH2_SCOPE=read write

# Custom headers (JSON format, optional)
# API_CUSTOM_HEADERS={"X-Custom-Header": "value"}

# Server configuration
PORT=8000
LOG_LEVEL=info

# Path to endpoints configuration file (optional, defaults to config/endpoints.json)
ENDPOINTS_CONFIG_PATH=config/endpoints.json
